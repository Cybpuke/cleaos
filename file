sudo nano /etc/systemd/system/airflow-webserver.service

Use:

[Unit]
Description=Airflow webserver
After=network.target

[Service]
EnvironmentFile=/etc/default/airflow
User=airflow
Group=airflow
Type=simple
ExecStart=/opt/airflow/venv/bin/python -m airflow webserver
Restart=always
RestartSec=5s

[Install]
WantedBy=multi-user.target

Do the same for scheduler:

sudo nano /etc/systemd/system/airflow-scheduler.service

Use:

[Unit]
Description=Airflow scheduler
After=network.target

[Service]
EnvironmentFile=/etc/default/airflow
User=airflow
Group=airflow
Type=simple
ExecStart=/opt/airflow/venv/bin/python -m airflow scheduler
Restart=always
RestartSec=5s

[Install]
WantedBy=multi-user.target

Then reload and restart:

sudo systemctl daemon-reload
sudo systemctl restart airflow-webserver
sudo systemctl restart airflow-scheduler
sudo systemctl status airflow-webserver --no-pager
sudo systemctl status airflow-scheduler --no-pager
