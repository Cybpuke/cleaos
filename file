sudo systemctl stop airflow-webserver || true
sudo systemctl stop airflow-scheduler || true
sudo systemctl stop airflow-worker || true

sudo mkdir -p /root/airflow-backup
sudo cp -a /opt/airflow/dags /root/airflow-backup/ 2>/dev/null || true
sudo cp -a /opt/airflow/airflow.cfg /root/airflow-backup/ 2>/dev/null || true


sudo rm -rf /opt/airflow/venv

sudo apt-get update
sudo apt-get install -y \
  python3.11 python3.11-venv python3.11-dev \
  build-essential gcc g++ \
  libpq-dev \
  unixodbc unixodbc-dev \
  libsasl2-dev libssl-dev libffi-dev \
  curl


sudo groupadd --system airflow 2>/dev/null || true
sudo useradd --system --gid airflow --home-dir /opt/airflow --shell /bin/bash airflow 2>/dev/null || true

sudo mkdir -p /opt/airflow
sudo mkdir -p /opt/airflow/dags
sudo mkdir -p /opt/airflow/logs
sudo mkdir -p /opt/airflow/plugins
sudo mkdir -p /opt/airflow/dag_generated_configs

sudo chown -R airflow:airflow /opt/airflow
sudo chmod -R 755 /opt/airflow


sudo -u airflow python3.11 -m venv /opt/airflow/venv
sudo -u airflow /opt/airflow/venv/bin/pip install --upgrade pip setuptools wheel


sudo -u airflow -H bash


export AIRFLOW_HOME=/opt/airflow
export AIRFLOW_VERSION=2.10.5
export PYTHON_VERSION=3.11
export OPENMETADATA_VERSION=1.12.1
export CONSTRAINT_URL="https://raw.githubusercontent.com/apache/airflow/constraints-${AIRFLOW_VERSION}/constraints-${PYTHON_VERSION}.txt"
source /opt/airflow/venv/bin/activate


pip install "apache-airflow==${AIRFLOW_VERSION}" --constraint "${CONSTRAINT_URL}"


pip install "openmetadata-ingestion[postgres,mysql,mssql,mssql-odbc,elasticsearch,opensearch]==${OPENMETADATA_VERSION}"
pip install "openmetadata-managed-apis==${OPENMETADATA_VERSION}"
